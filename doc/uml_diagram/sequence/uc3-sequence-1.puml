@startuml
title UC-3 차일드락 상태 표시 제공

actor Driver
control "ChildLockController" as CLC
entity "ChildLockState" as CLS
boundary "Door Panel Interface" as DPI

CLC -> CLS : getState()
activate CLS
CLS --> CLC : childLockState
deactivate CLS

alt 차일드락 ON 상태
    CLC -> DPI : turnOnLED()
    activate DPI
    DPI --> CLC : LEDOn
    deactivate DPI
else 차일드락 OFF 상태
    CLC -> DPI : turnOffLED()
    activate DPI
    DPI --> CLC : LEDOff
    deactivate DPI
end
@enduml
